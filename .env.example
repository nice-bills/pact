# Chain: "base-sepolia" or "avalanche-fuji"
CHAIN_NAME=base-sepolia

# Private key for deploying contracts and signing transactions
DEPLOYER_PRIVATE_KEY=0x...

# Base Sepolia RPC
BASE_SEPOLIA_RPC=https://sepolia.base.org

# Avalanche Fuji RPC (for Avalanche track)
AVALANCHE_FUJI_RPC=https://api.avax-test.network/ext/bc/C/rpc

# IPFS gateway (for evidence uploads)
IPFS_GATEWAY=https://w3s.link

# GenLayer Intelligent Contract address (enables AI consensus evaluation)
GENLAYER_IC_ADDRESS=

# Deployed contract addresses (set after deployment)
AGENTIC_COMMERCE_ADDRESS=
POOL_SAFE_ADDRESS=

# Safe multisig owners (comma-separated addresses)
SAFE_OWNERS=

# Safe multisig threshold
SAFE_THRESHOLD=2
