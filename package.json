{
  "name": "mutual-aid-pool",
  "version": "0.1.0",
  "description": "Agent-managed mutual aid fund using ERC-8183, ERC-8004, Safe multisig, and Superfluid",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:sol": "forge test",
    "test:e2e": "playwright test",
    "demo": "tsx src/demo/run-demo.ts",
    "serve": "tsx src/cli/commands/serve.ts",
    "verify": "tsx scripts/verify.ts",
    "cleanup": "tsx scripts/cleanup.ts",
    "demo:fresh": "tsx src/demo/run-demo.ts",
    "deploy:erc8183": "tsx src/deploy/deploy-erc8183.ts",
    "deploy:safe": "tsx src/deploy/create-safe.ts",
    "deploy:all": "tsx src/deploy/deploy-all.ts",
    "wallet:check": "tsx src/deploy/check-wallet.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "dependencies": {
    "@safe-global/api-kit": "^4.0.1",
    "@safe-global/protocol-kit": "^6.1.2",
    "@superfluid-finance/sdk-core": "^0.9.0",
    "commander": "^13.0.0",
    "ethers": "^5.8.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "viem": "^2.47.4",
    "vitest": "^4.1.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^3.0.0",
    "@nomicfoundation/hardhat-viem": "^3.0.4",
    "@openzeppelin/contracts": "^5.6.1",
    "@playwright/test": "^1.50.0",
    "chai": "^6.2.2",
    "dotenv": "^17.3.1",
    "forge-std": "^1.1.2",
    "hardhat": "^3.1.12"
  }
}
